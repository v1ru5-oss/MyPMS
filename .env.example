# Скопируйте в .env.local и подставьте значения из Supabase (Settings → API).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Опционально: домен для логина без «@» (см. AuthContext)
# VITE_AUTH_EMAIL_DOMAIN=hotel.local

# Только для scripts/migrate-data.mjs (импорт из старого localStorage) — не коммитьте service role.
# SUPABASE_SERVICE_ROLE_KEY=
# MIGRATE_EMAIL_DOMAIN=example.com
# MIGRATE_USER_PASSWORD=

# Edge Function create-user (Supabase → Edge Functions → Secrets):
# APP_PUBLIC_URL=https://...   — URL фронта; в письме-приглашении ссылка ведёт на …/login
# В Supabase → Authentication → URL configuration добавьте Redirect URL: https://ваш-фронт/login
